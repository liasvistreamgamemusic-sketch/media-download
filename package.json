{
  "name": "media-downloader",
  "version": "1.4.0",
  "description": "URL を貼り付けるだけで高品質メディアをローカル保存するデスクトップアプリ（Windows / macOS）",
  "main": "./out/main/index.js",
  "author": "liasvistreamgamemusic-sketch",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liasvistreamgamemusic-sketch/media-download.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "fetch-binaries": "node scripts/fetch-binaries.mjs",
    "make-icons": "node scripts/make-icons.mjs",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run fetch-binaries -- --mac-universal && npm run build && electron-builder --mac --universal",
    "package:dir": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "execa": "^9.6.1",
    "lucide-react": "^1.17.0",
    "tree-kill": "^1.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "electron": "^39.2.6",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.8"
  }
}
